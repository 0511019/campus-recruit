generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  username     String?        @unique
  phone        String?        @unique
  wechatId     String?        @unique
  passwordHash String?
  nickname     String         @default("")
  role         String         @default("user")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  favorites    Favorite[]
  subscriptions Subscription[]
  notifications Notification[]
  @@map("users")
}

model SmsCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  type      String
  expiresAt DateTime @map("expires_at")
  used      Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  @@index([phone, type, createdAt(sort: Desc)])
  @@map("sms_codes")
}

model Activity {
  id                   String   @id @default(uuid())
  title                String
  targetAudience       String   @default("regional") @map("target_audience")
  region               String   @default("[]")
  universities         String   @default("[]")
  graduateYears        String   @default("[]") @map("graduate_years")
  activityType         String   @map("activity_type")
  format               String   @default("offline")
  platform             String?
  location             String?
  status               String   @default("preview")
  registrationStatus   String   @default("open") @map("registration_status")
  activityStartDate    String   @map("activity_start_date")
  activityEndDate      String   @map("activity_end_date")
  registrationDeadline String   @map("registration_deadline")
  enterpriseRegUrl     String?  @map("enterprise_reg_url")
  enterpriseRegMethod  String?  @map("enterprise_reg_method")
  enterpriseContact    String?  @map("enterprise_contact")
  brief                String?
  sourceLinks          String   @default("[]") @map("source_links")
  isVerified           Int      @default(0) @map("is_verified")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  favorites            Favorite[]
  notifications        Notification[]
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([registrationDeadline])
  @@map("activities")
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  activityId String   @map("activity_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  @@unique([userId, activityId])
  @@index([userId])
  @@map("favorites")
}

model Subscription {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String   @default("默认订阅")
  regions        String   @default("[]")
  universities   String   @default("[]")
  graduateYears  String   @default("[]") @map("graduate_years")
  activityTypes  String   @default("[]") @map("activity_types")
  notifyChannels String   @default("[\"in-app\"]") @map("notify_channels")
  isActive       Int      @default(1) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("subscriptions")
}

model Notification {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  type       String
  title      String
  body       String
  activityId String?   @map("activity_id")
  isRead     Int       @default(0) @map("is_read")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}
